# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local sqlite db
*.db
*.db-journal

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


# Prisma client is generated into src/generated/prisma (we commit it for predictable deploys)
# If you prefer generating on CI only, add it back to .gitignore.
# /src/generated/prisma
