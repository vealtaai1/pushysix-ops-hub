{
  "name": "pushysix-ops-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prebuild": "npm run prisma:generate && npm run prisma:migrate:deploy",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate:deploy": "node -e \"if(process.env.PRISMA_MIGRATE_DEPLOY==='true'){require('child_process').execSync('npx prisma migrate deploy',{stdio:'inherit'})}else{console.log('Skipping prisma migrate deploy (set PRISMA_MIGRATE_DEPLOY=true to enable)')}\"",
    "assert:retainers": "node scripts/retainers.assert.mjs",
    "prisma:seed": "npx prisma db seed"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.19.2",
    "date-fns": "^4.1.0",
    "jsqr": "^1.4.0",
    "next": "15.1.12",
    "next-auth": "5.0.0-beta.25",
    "postmark": "^4.0.5",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "resend": "^6.9.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bcryptjs": "^2.4.6",
    "eslint": "8.57.0",
    "eslint-config-next": "15.1.12",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
