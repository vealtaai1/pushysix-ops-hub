{
  "name": "pushysix-ops-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prebuild": "npm run prisma:generate && npm run prisma:migrate:deploy",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",

    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "node -e \"if(!process.env.DATABASE_URL){console.log('Skipping prisma migrate deploy (DATABASE_URL not set)');process.exit(0)}\" && prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "date-fns": "^4.1.0",
    "next": "16.1.6",
    "postmark": "^4.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
